{
  "env": {
    "EDITOR": "zed --wait",
    "VISUAL": "zed --wait"
  },
  "permissions": {
    "allow": [
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cat:*)",
      "Bash(command -v:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git clean:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(go vet:*)",
      "Bash(mise ls-remote:*)",
      "Bash(mise registry:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm run check)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(tee:*)",
      "Bash(tree:*)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "claude-fable-5[1m]",
  "fallbackModel": [
    "claude-opus-4-7",
    "claude-sonnet-5"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prompt-repetition-nudge.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-gate.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_NOTIFY_SOUND= ~/.claude/hooks/notify.sh Stop"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_NOTIFY_SOUND=Ping ~/.claude/hooks/notify.sh Notification"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh Notification"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh SessionStart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh SessionEnd"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "plugin-dev@claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      },
      "autoUpdate": true
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "advisorModel": "fable"
}
